# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script for Unix-like systems
#
# Optional ENV vars
# -----------------
#   JAVA_HOME - location of a JDK home dir, layer 1
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
#     e.g. to debug Maven itself, use
#       set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_SKIP_RC" ]; then
  if [ -f /etc/mavenrc ]; then
    . /etc/mavenrc
  fi
  if [ -f "$HOME/.mavenrc" ]; then
    . "$HOME/.mavenrc"
  fi
fi

# OS specific support. $var _must_ be set to either true or false.
cygwin=false
darwin=false
os400=false
hpux=false
case "`uname`" in
  CYGWIN*) cygwin=true;;
  Darwin*) darwin=true;;
  OS400*) os400=true;;
  HP-UX*) hpux=true;;
esac

# Resolve $HOLD_JAVA_HOME
if [ -z "$JAVA_HOME" ]; then
  JAVA_PATH=`which java`
  if [ -n "$JAVA_PATH" ]; then
    JAVA_HOME=`dirname $(dirname $(readlink -f $JAVA_PATH))`
  fi
fi

if [ -z "$JAVA_HOME" ]; then
  if [ -r /usr/lib/java-guest ]; then
    JAVA_HOME=/usr/lib/java-guest
  fi
fi

# Resolve JAVA_EXE
if [ -n "$JAVA_HOME" ]; then
  JAVA_EXE="$JAVA_HOME/bin/java"
else
  JAVA_EXE="java"
fi

# For Cygwin, ensure paths are in UNIX format before anything is touched
if $cygwin; then
  [ -n "$JAVA_HOME" ] && JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
fi

# For OS400
if $os400; then
  # Support for 8-bit characters in arguments
  export QIBM_MULTI_CONF_ARGS=1
fi

WRAPPER_JAR_PATH=".mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES_PATH=".mvn/wrapper/maven-wrapper.properties"

# Check if the wrapper jar exists
if [ ! -f "$WRAPPER_JAR_PATH" ]; then
  # If not, try to download it
  export WRAPPER_URL=$(grep "^wrapperUrl" "$WRAPPER_PROPERTIES_PATH" | cut -d'=' -f2-)
  if [ -z "$WRAPPER_URL" ]; then
    WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
  fi

  echo "Downloading Maven Wrapper jar from $WRAPPER_URL..."
  if command -v wget > /dev/null; then
    wget -O "$WRAPPER_JAR_PATH" "$WRAPPER_URL"
  elif command -v curl > /dev/null; then
    curl -o "$WRAPPER_JAR_PATH" "$WRAPPER_URL"
  else
    echo "Error: Neither wget nor curl found. Please install one of them or download the wrapper jar manually."
    exit 1
  fi
fi

CLASSPATH="$WRAPPER_JAR_PATH"

exec "$JAVA_EXE" \
  $MAVEN_OPTS \
  -classpath "$CLASSPATH" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
